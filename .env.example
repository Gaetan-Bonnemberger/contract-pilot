# ─────────────────────────────────────────────────────────────────────────────
# Contract Pilot — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs avant le premier lancement
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de données ────────────────────────────────────────────────────────
# Avec Docker Compose : laisser tel quel (PostgreSQL dans le container)
# Avec un PostgreSQL externe : adapter l'URL
DATABASE_URL=postgresql://contractpilot:CHANGER_MOT_DE_PASSE@localhost:5432/contractpilot

# Mot de passe PostgreSQL (utilisé par docker-compose.yml)
DB_PASSWORD=CHANGER_MOT_DE_PASSE

# ── Authentification ───────────────────────────────────────────────────────
# Secret de chiffrement des sessions — DOIT être changé en production
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=GENERER_UN_SECRET_FORT_ICI

# URL publique de l'application (sans slash final)
# Exemple : http://192.168.1.50:3000 ou https://contract-pilot.monentreprise.fr
NEXTAUTH_URL=http://localhost:3000

# ── Port de l'application ──────────────────────────────────────────────────
APP_PORT=3000

# ── Stockage des fichiers uploadés ────────────────────────────────────────
STORAGE_PATH=./storage

# ── IA — Analyse automatique des marchés ─────────────────────────────────
# Fournisseur d'analyse : "ollama" (LLM local, recommandé RGPD), "anthropic" (cloud), "mock".
# Par défaut : "anthropic" si ANTHROPIC_API_KEY est renseignée, sinon "mock".
LLM_PROVIDER=ollama

# ── IA locale via Ollama (conformité RGPD : aucune donnée ne quitte la machine) ──
# Prérequis : installer Ollama (https://ollama.com) puis : ollama pull mistral:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b
# Fenêtre de contexte (num_ctx = tokens d'entrée + de sortie).
# En cas d'"out of memory" au chargement du modèle, redescendre à 8192.
OLLAMA_NUM_CTX=16384
# Nombre max de tokens générés en sortie.
OLLAMA_NUM_PREDICT=4096

# ── IA cloud via Anthropic (optionnel — utilisé si LLM_PROVIDER=anthropic) ──
# Sans clé et sans Ollama, l'application fonctionne en mode démonstration réaliste.
# Obtenir une clé sur : https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Email — Notifications (optionnel) ─────────────────────────────────────
# Sans configuration, les emails sont désactivés (aucune erreur).
# Gmail : créer un mot de passe d'application sur myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM="Contract Pilot <votre.email@gmail.com>"
